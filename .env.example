# ─────────────────────────────────────────────
# Buyer Lead Intake Agent — Environment Config
# Copy this to .env and fill in your key(s)
# ─────────────────────────────────────────────

# ── Provider selection ──────────────────────
# Options: groq | openrouter | openai
# Default: groq
LLM_PROVIDER=groq

# ── Model override (optional) ───────────────
# Leave blank to use the provider default.
# OpenRouter examples:
#   meta-llama/llama-3.3-70b-instruct   (free)
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   google/gemini-flash-1.5
#   mistralai/mistral-7b-instruct        (free)
LLM_MODEL=

# ── API Keys ────────────────────────────────
# Only the key for your chosen LLM_PROVIDER is required.

# Groq (free tier, 100K tokens/day) → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (one key for 100+ models) → https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI direct → https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
